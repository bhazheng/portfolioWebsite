{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "akbarlucky",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./.output/public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
