---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy — Akbar Lucky Basuki">
  <!-- ponytail: simple static policy page that bypasses the header navbar -->
  <div class="bg-glass backdrop-blur-md border border-line-dark rounded-2xl p-12 max-[768px]:p-6 shadow-glass max-w-3xl mx-auto my-12">
    <h1 class="font-display font-bold text-3xl tracking-tight text-paper mb-6">Privacy Policy</h1>
    <p class="font-mono text-xs text-brass-soft mb-8">Last updated: July 2026</p>
    
    <div class="font-body text-text-secondary leading-relaxed space-y-6">
      <p>Your privacy is important. This portfolio does not collect, track, or share any personal data or usage analytics.</p>
      <p>Any information you send via direct email or contact channels is used solely to respond to your inquiries.</p>
    </div>
    
    <div class="mt-8 pt-6 border-t border-line">
      <a href="/" class="font-mono text-xs text-brass-soft hover:text-paper transition-colors duration-150">← Back to Home</a>
    </div>
  </div>
</Layout>
