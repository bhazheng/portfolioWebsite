---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms & Conditions — Akbar Lucky Basuki">
  <!-- ponytail: simple static terms page that bypasses the header navbar -->
  <div class="bg-glass backdrop-blur-md border border-line-dark rounded-2xl p-12 max-[768px]:p-6 shadow-glass max-w-3xl mx-auto my-12">
    <h1 class="font-display font-bold text-3xl tracking-tight text-paper mb-6">Terms & Conditions</h1>
    <p class="font-mono text-xs text-brass-soft mb-8">Last updated: July 2026</p>
    
    <div class="font-body text-text-secondary leading-relaxed space-y-6">
      <p>By accessing this website, you agree to view the portfolio content for professional assessment, collaboration, or hiring purposes only.</p>
      <p>All project case studies, design concepts, and visual assets are copyright of their respective owners.</p>
    </div>
    
    <div class="mt-8 pt-6 border-t border-line">
      <a href="/" class="font-mono text-xs text-brass-soft hover:text-paper transition-colors duration-150">← Back to Home</a>
    </div>
  </div>
</Layout>
