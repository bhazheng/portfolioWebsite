---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Akbar Lucky Basuki — Featured Projects">
  <!-- ponytail: compact projects layout with density 9 adjustments -->
  <div class="flex items-baseline justify-between border-b border-line pb-2 mb-5">
    <h2 class="font-display font-bold text-[clamp(1.4rem,3vw,1.9rem)] tracking-tight flex items-center gap-2 before:content-['//'] before:font-mono before:text-[0.55em] before:font-medium before:text-brass-soft before:tracking-tighter before:opacity-75">
      Featured Projects
    </h2>
    <div class="font-mono text-[10px] font-semibold tracking-wider text-teal bg-teal/15 px-2.5 py-0.5 rounded-full">02 items</div>
  </div>

  <div class="bg-glass backdrop-blur-md border border-line-dark rounded-2xl p-5 shadow-glass max-[768px]:p-4">
    <div class="grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">
      <div class="bg-glass-card border border-line-dark rounded-xl p-5 shadow-glass-inner flex flex-col justify-between hover:-translate-y-1 hover:border-brass hover:shadow-card-hover active:scale-[0.99] transition-all duration-300 ease-spring">
        <div>
          <div class="font-mono text-[10px] font-semibold tracking-widest text-brass-soft uppercase">Thesis · NLP & Analytics</div>
          <h3 class="font-display font-bold text-base tracking-tight mt-1.5 leading-snug">Sentiment Analysis for Product Improvement (IndoBERT)</h3>
          <p class="font-body text-xs text-text-secondary/75 mt-2 leading-relaxed max-w-prose">
            Applying Root Cause Analysis to large-scale qualitative user reviews in the Ajaib Kripto app — from problem formulation to concrete product improvement recommendations.
          </p>
          <div class="flex gap-1.5 flex-wrap mt-4">
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">IndoBERT</span>
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">Python NLP</span>
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">RCA Analysis</span>
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">Looker Studio</span>
          </div>
        </div>
        <div class="mt-4 font-mono text-xs text-teal border-t border-dashed border-line pt-3 tabular-nums">Applied&nbsp;<b class="font-display font-[800] text-sm tracking-tight text-paper tabular-nums">RCA</b>&nbsp;framework to real feedback</div>
      </div>
      
      <div class="bg-glass-card border border-line-dark rounded-xl p-5 shadow-glass-inner flex flex-col justify-between hover:-translate-y-1 hover:border-brass hover:shadow-card-hover active:scale-[0.99] transition-all duration-300 ease-spring">
        <div>
          <div class="font-mono text-[10px] font-semibold tracking-widest text-brass-soft uppercase">Capstone · Computer Vision</div>
          <h3 class="font-display font-bold text-base tracking-tight mt-1.5 leading-snug">Semar — Wayang Image Classification</h3>
          <p class="font-body text-xs text-text-secondary/75 mt-2 leading-relaxed max-w-prose">
            Led a cross-disciplinary team collaboration to build an image classifier to preserve Indonesian cultural heritage, covering model design through prediction system integration.
          </p>
          <div class="flex gap-1.5 flex-wrap mt-4">
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">TensorFlow</span>
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">CNN Model</span>
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">Cloud Api</span>
            <span class="font-mono text-[9px] text-text-muted bg-glass-ghost border border-line rounded px-2 py-0.5">Python API</span>
          </div>
        </div>
        <div class="mt-4 font-mono text-xs text-teal border-t border-dashed border-line pt-3 tabular-nums">Successfully achieved&nbsp;<b class="font-display font-[800] text-sm tracking-tight text-paper tabular-nums">91%</b>&nbsp;accuracy</div>
      </div>
    </div>
  </div>
</Layout>
