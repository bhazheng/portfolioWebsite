---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio of Akbar Lucky Basuki, a Business Analyst and Data Storyteller who translates raw data into regulatory-grade decisions." } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.html';
---

<!DOCTYPE html>
<html lang="en" class={isHome ? "snap-y snap-mandatory scroll-smooth" : "scroll-smooth"}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600;700&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" />
  <ClientRouter />
</head>
<body>
  <!-- ponytail: translated skip-link -->
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="bg-grid"></div>
  <div class="noise-overlay" aria-hidden="true"></div>
  <Navbar currentPath={currentPath} />
  <main id="main-content" class="max-w-[960px] mx-auto px-6 pt-16 pb-8 min-h-dvh flex flex-col justify-center scroll-mt-[90px]">
    <slot />
    <Footer class={isHome ? "snap-start" : ""} />
  </main>
</body>
</html>
